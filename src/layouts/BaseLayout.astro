---
import '../styles/global.css';
import { siteLinks } from '../data/siteLinks';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Dewen Lei is a Computational Mathematics student at the University of Waterloo writing about software engineering, algorithms, AI systems, backend engineering, and applied mathematics.',
} = Astro.props;

const navItems = [
  { href: '/blog/', label: 'Writing' },
  { href: siteLinks.resume, label: 'Resume' },
  { href: siteLinks.github, label: 'GitHub' },
];

const isActive = (href: string) =>
  href.startsWith('/') && href !== siteLinks.resume
    ? Astro.url.pathname.startsWith(href)
    : false;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="site-title" href="/">Dewen Lei</a>
      <nav aria-label="Main navigation">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class:list={{ active: isActive(item.href) }}
              target={item.href.startsWith('http') ? '_blank' : undefined}
              rel={item.href.startsWith('http') ? 'noreferrer' : undefined}
            >
              {item.label}
            </a>
          ))
        }
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div>
        <strong>Dewen Lei</strong>
      </div>
      <nav aria-label="Footer links">
        <a href={siteLinks.github} target="_blank" rel="noreferrer">GitHub</a>
        <a href={siteLinks.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
        <a href={siteLinks.resume}>Resume</a>
        <a href={siteLinks.email}>Email</a>
      </nav>
      <p>Built with Astro. Deployed on GitHub Pages.</p>
    </footer>
  </body>
</html>
