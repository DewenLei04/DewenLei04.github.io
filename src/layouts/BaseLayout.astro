---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Personal website and blog of Dewen Lei.',
} = Astro.props;

const navItems = [
  { href: '/', label: 'Home' },
  { href: '/blog/', label: 'Blog' },
  { href: '/about/', label: 'About' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="site-title" href="/">Dewen Lei</a>
      <nav aria-label="Main navigation">
        {
          navItems.map((item) => (
            <a href={item.href} class:list={{ active: Astro.url.pathname === item.href }}>
              {item.label}
            </a>
          ))
        }
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>Built with Astro. Published on GitHub Pages.</p>
    </footer>
  </body>
</html>
