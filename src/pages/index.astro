---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteLinks } from '../data/siteLinks';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('en', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  }).format(date);

const categorySlug = (category: string) =>
  category.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');

const profileJson = JSON.stringify(
  {
    name: 'Dewen Lei',
    field: 'Computational Mathematics',
    writes_about: [
      'software engineering',
      'algorithms',
      'AI systems',
      'applied mathematics',
    ],
    tools: ['Python', 'TypeScript', 'React', 'Node.js', 'SQL', 'Docker'],
  },
  null,
  2
);
---

<BaseLayout
  title="Dewen Lei"
  description="Dewen Lei is a Computational Mathematics student at the University of Waterloo writing about software engineering, algorithms, AI systems, backend engineering, and applied mathematics."
>
  <section class="hero">
    <div class="hero-content">
      <p class="eyebrow">PUBLIC TECHNICAL NOTEBOOK</p>
      <h1>Dewen Lei</h1>
      <p class="identity-line">
        Computational Mathematics @ University of Waterloo.
      </p>
      <p class="hero-copy">
        I use this site to make my technical learning explicit: software
        engineering, algorithms, AI systems, and the mathematical ideas behind
        them.
      </p>
      <div class="hero-actions" aria-label="Primary links">
        <a class="button primary" href="/blog/">Read writing</a>
        <a class="button secondary" href={siteLinks.email}>Email me</a>
      </div>
    </div>

    <aside class="profile-card" aria-label="Technical profile">
      <div class="code-window-bar">
        <span>profile.json</span>
        <span class="code-dot"></span>
      </div>
      <pre><code>{profileJson}</code></pre>
    </aside>
  </section>

  <section class="section-grid" aria-labelledby="latest-posts">
    <div>
      <p class="eyebrow">Latest writing</p>
      <h2 id="latest-posts">Recent notes</h2>
    </div>
    <div class="post-list">
      {
        posts.map((post) => (
          <article class="post-card">
            <div class="post-card-meta">
              <a class="category-link" href={`/blog/category/${categorySlug(post.data.category)}/`}>
                {post.data.category}
              </a>
              <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
            </div>
            <h3>
              <a href={`/blog/${post.id}/`}>{post.data.title}</a>
            </h3>
            <p>{post.data.description}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="site-note" aria-labelledby="about-this-site">
    <p class="eyebrow">About this site</p>
    <h2 id="about-this-site">About this site</h2>
    <p>
      I write short technical notes when I want to clarify an idea, fix a
      misunderstanding, or preserve a useful explanation for later. The goal is
      not to publish polished essays, but to build a durable record of learning.
    </p>
  </section>
</BaseLayout>
