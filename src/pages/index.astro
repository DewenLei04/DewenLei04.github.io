---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteLinks } from '../data/siteLinks';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('en', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  }).format(date);

const categorySlug = (category: string) =>
  category.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');

const profileJson = JSON.stringify(
  {
    school: 'University of Waterloo',
    field: 'Computational Mathematics',
    focus: ['software engineering', 'AI systems', 'algorithms'],
    stack: ['Python', 'TypeScript', 'React', 'Node.js', 'SQL', 'Docker'],
  },
  null,
  2
);
---

<BaseLayout
  title="Dewen Lei"
  description="Dewen Lei is a Computational Mathematics student at the University of Waterloo writing about software engineering, algorithms, AI systems, backend engineering, and applied mathematics."
>
  <section class="hero">
    <div class="hero-content">
      <p class="eyebrow">Computational Mathematics · Software Engineering</p>
      <h1>Dewen Lei</h1>
      <p class="identity-line">
        Computational Mathematics student at the University of Waterloo.
      </p>
      <p class="hero-copy">
        I write about software engineering, algorithms, AI systems, and applied
        mathematics. This site is my public technical notebook: a place to
        document what I learn, what I misunderstand, and how my understanding
        changes over time.
      </p>
      <p class="focus-line">
        Currently focused on backend engineering, AI tools, algorithms, and systems.
      </p>
      <div class="hero-actions" aria-label="Primary links">
        <a class="button primary" href={siteLinks.email}>Email</a>
        <a class="button secondary" href={siteLinks.github} target="_blank" rel="noreferrer">GitHub</a>
        <a class="button secondary" href={siteLinks.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
        <a class="button secondary" href={siteLinks.resume}>Resume</a>
      </div>
    </div>

    <aside class="profile-card" aria-label="Technical profile">
      <div class="code-window-bar">
        <span>profile.json</span>
        <span class="code-dot"></span>
      </div>
      <pre><code>{profileJson}</code></pre>
    </aside>
  </section>

  <section class="section-grid" aria-labelledby="latest-posts">
    <div>
      <p class="eyebrow">Latest writing</p>
      <h2 id="latest-posts">Recent notes</h2>
    </div>
    <div class="post-list">
      {
        posts.map((post) => (
          <article class="post-card">
            <div class="post-card-meta">
              <a class="category-link" href={`/blog/category/${categorySlug(post.data.category)}/`}>
                {post.data.category}
              </a>
              <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
            </div>
            <h3>
              <a href={`/blog/${post.id}/`}>{post.data.title}</a>
            </h3>
            <p>{post.data.description}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="site-note" aria-labelledby="about-this-site">
    <p class="eyebrow">About this site</p>
    <h2 id="about-this-site">A technical notebook for learning in public.</h2>
    <p>
      This site is a technical notebook for software engineering, algorithms, AI
      systems, and mathematical ideas I am learning. I use it to make my
      understanding explicit and reusable.
    </p>
  </section>
</BaseLayout>
